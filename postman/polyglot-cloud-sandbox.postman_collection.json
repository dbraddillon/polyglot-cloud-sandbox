          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{claims_api_url}}/claims",
            "body": { "mode": "raw", "raw": "{\"memberName\": \"Jordan Rivera\", \"lineItems\": [{\"serviceDescription\": \"Annual wellness visit\", \"billedAmount\": 182.50}]}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Get claim",
          "request": { "method": "GET", "url": "{{claims_api_url}}/claims/{{claim_id}}" }
        },
        {
          "name": "Approve claim",
          "request": { "method": "POST", "url": "{{claims_api_url}}/claims/{{claim_id}}/approve" }
        }
      ]
    },
    {
      "name": "events-api",
      "item": [
        {
          "name": "Publish event",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('event_id', json.id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{events_api_url}}/events",
            "body": { "mode": "raw", "raw": "{\"type\": \"claim.submitted\", \"payload\": \"claim-123\"}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "List processed events",
          "request": { "method": "GET", "url": "{{events_api_url}}/events" }
        },
        {
          "name": "Get event (poll until processed - may 404 briefly)",
          "request": { "method": "GET", "url": "{{events_api_url}}/events/{{event_id}}" }
        }
      ]
    },
    {
      "name": "claims-intake-api",
      "item": [
        {
          "name": "List batches",
          "request": { "method": "GET", "url": "{{claims_intake_api_url}}/claims-intake" }
        },
        {
          "name": "Upload a small CSV (streamed synchronously)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('batch_id', json.batchId);"
          ] } }],
          "request": {
            "method": "POST",
            "url": "{{claims_intake_api_url}}/claims-intake",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": "Select a small CSV - see the sample's deploy.sh for the generated column layout (claimId,memberId,serviceDate,serviceDescription,billedAmount)" }
              ]
            }
          }
        },
        {
          "name": "Get batch status",
          "request": { "method": "GET", "url": "{{claims_intake_api_url}}/claims-intake/{{batch_id}}" }
        }
      ]
    },
    {
      "name": "python-api",
      "description": "Same Lambda + API Gateway shape as hello-api, Python runtime. Run ./deploy.sh, paste its printed invoke URL into python_api_invoke_url.",
      "item": [
        {
          "name": "Greet",
          "request": { "method": "GET", "url": "{{python_api_invoke_url}}?name=Postman" }
        }
      ]
    },
    {
