          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{catalog_api_url}}/plans",
            "body": { "mode": "raw", "raw": "{\"name\": \"Silver PPO Plan\", \"monthlyPremium\": 399.00}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Get plan",
          "request": { "method": "GET", "url": "{{catalog_api_url}}/plans/{{plan_id}}" }
        },
        {
          "name": "Update plan",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{catalog_api_url}}/plans/{{plan_id}}",
            "body": { "mode": "raw", "raw": "{\"name\": \"Silver PPO Plan\", \"monthlyPremium\": 425.00}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Delete plan",
          "request": { "method": "DELETE", "url": "{{catalog_api_url}}/plans/{{plan_id}}" }
        }
      ]
    },
    {
      "name": "claims-api",
      "item": [
        {
          "name": "List claims",
          "request": { "method": "GET", "url": "{{claims_api_url}}/claims" }
        },
        {
          "name": "Create claim",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
