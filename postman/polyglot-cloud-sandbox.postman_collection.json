{
  "info": {
    "_postman_id": "b7e6d6b0-6b1b-4b1a-9b0a-polyglotsandbox",
    "name": "polyglot-cloud-sandbox",
    "description": "One request collection covering every sample's endpoints. Start whichever sample's ./deploy.sh you want to exercise first, then run its folder here - each one is a self-contained, runnable flow (create -> read -> update -> delete, in that order), with the create requests' Tests scripts auto-capturing ids into collection variables so the follow-up requests just work. Imports natively into Postman; Insomnia can import this file directly too (Insomnia's own importer reads Postman v2.1 collections).\n\nhello-api and python-api are the two exceptions: their invoke URL includes a Pulumi-generated API id that's different on every deploy, so their folders use empty {{hello_api_invoke_url}}/{{python_api_invoke_url}} variables - copy the \"Local invoke URL\" line deploy.sh prints and paste it into that collection variable (Postman: collection > Variables tab) before running those two requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "hello_api_invoke_url", "value": "", "description": "Paste deploy.sh's printed local invoke URL here" },
    { "key": "task_api_url", "value": "http://localhost:8080" },
    { "key": "search_api_url", "value": "http://localhost:8081" },
    { "key": "catalog_api_url", "value": "http://localhost:8082" },
    { "key": "claims_api_url", "value": "http://localhost:8083" },
    { "key": "events_api_url", "value": "http://localhost:8084" },
    { "key": "claims_intake_api_url", "value": "http://localhost:8085" },
    { "key": "node_api_url", "value": "http://localhost:8086" },
    { "key": "clojure_datomic_api_url", "value": "http://localhost:8087" },
    { "key": "attachments_api_url", "value": "http://localhost:8088" },
    { "key": "python_api_invoke_url", "value": "", "description": "Paste deploy.sh's printed local invoke URL here" },
    { "key": "task_id", "value": "" },
    { "key": "plan_id", "value": "" },
    { "key": "claim_id", "value": "" },
    { "key": "document_id", "value": "" },
    { "key": "event_id", "value": "" },
    { "key": "batch_id", "value": "" },
    { "key": "notice_id", "value": "" },
    { "key": "provider_id", "value": "" },
    { "key": "attachment_key", "value": "" }
  ],
  "item": [
    {
      "name": "hello-api",
      "description": "Lambda + API Gateway via Floci. Run ./deploy.sh, copy its printed local invoke URL into the hello_api_invoke_url collection variable.",
      "item": [
        {
          "name": "Greet",
          "request": { "method": "GET", "url": "{{hello_api_invoke_url}}?name=Postman" }
        }
      ]
    },
    {
      "name": "task-api",
      "item": [
        {
          "name": "List tasks",
          "request": { "method": "GET", "url": "{{task_api_url}}/tasks" }
        },
        {
          "name": "Create task",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('task_id', json.id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{task_api_url}}/tasks",
            "body": { "mode": "raw", "raw": "{\"title\": \"Schedule annual wellness visit\"}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Get task",
          "request": { "method": "GET", "url": "{{task_api_url}}/tasks/{{task_id}}" }
        },
        {
          "name": "Move to IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{task_api_url}}/tasks/{{task_id}}/status",
            "body": { "mode": "raw", "raw": "{\"status\": \"IN_PROGRESS\"}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Move to DONE",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{task_api_url}}/tasks/{{task_id}}/status",
            "body": { "mode": "raw", "raw": "{\"status\": \"DONE\"}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Delete task",
          "request": { "method": "DELETE", "url": "{{task_api_url}}/tasks/{{task_id}}" }
        }
      ]
    },
    {
      "name": "search-api",
      "item": [
        {
          "name": "Index a document",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('document_id', json.id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{search_api_url}}/documents",
            "body": { "mode": "raw", "raw": "{\"title\": \"Annual wellness visit guidance\", \"body\": \"What to expect at your annual checkup.\"}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Get document",
          "request": { "method": "GET", "url": "{{search_api_url}}/documents/{{document_id}}" }
        },
        {
          "name": "Search documents",
          "request": { "method": "GET", "url": "{{search_api_url}}/documents/search?q=wellness" }
        }
      ]
    },
    {
      "name": "catalog-api",
      "item": [
        {
          "name": "List plans",
          "request": { "method": "GET", "url": "{{catalog_api_url}}/plans" }
        },
        {
          "name": "Create plan",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
